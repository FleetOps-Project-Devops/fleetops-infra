# Database Config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
DB_HOST=postgres
DB_PORT=5432

# Authentication
JWT_SECRET=super_secret_jwt_key_that_should_be_long_enough_for_hs256_algorithm
JWT_EXPIRATION=86400000

# Backend Service URLs (used internally by services)
AUTH_SERVICE_URL=http://auth-service:8080
PRODUCT_SERVICE_URL=http://product-service:8080
CART_SERVICE_URL=http://cart-service:8080
ORDER_SERVICE_URL=http://order-service:8080

# CORS
CORS_ALLOWED_ORIGINS=*

# Redis Cache (used by product-service)
REDIS_HOST=redis
REDIS_PORT=6379
